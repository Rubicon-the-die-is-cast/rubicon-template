# .env.example — скопируй в .env и заполни значения
# НИКОГДА не коммить .env (gitleaks pre-commit hook блокирует)

# ── App ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR
ENVIRONMENT=development # development | staging | production
APP_PORT={{ app_port }}

{% if include_postgres %}
# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_this_strong_password
DATABASE_URL=postgresql+asyncpg://{{ project_slug }}:change_this_strong_password@localhost:5432/{{ project_slug }}_db
{% endif %}
{% if include_redis %}
# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
{% endif %}
