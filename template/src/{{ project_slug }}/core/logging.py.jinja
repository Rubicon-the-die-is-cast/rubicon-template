"""Centralized logging setup via loguru.

Call setup_logging() once at the entry point of your application.
Everywhere else: `from loguru import logger`

Usage:
    from {{ project_slug }}.core.logging import setup_logging
    setup_logging(level="INFO")
"""
import sys

from loguru import logger


def setup_logging(level: str = "INFO") -> None:
    """Configure loguru sinks: colored stderr + rotating JSON file."""
    logger.remove()  # drop the default handler

    # ── Console: colored, human-readable ─────────────────────────────────────
    logger.add(
        sys.stderr,
        level=level,
        format=(
            "<green>{time:YYYY-MM-DD HH:mm:ss.SSS}</green> | "
            "<level>{level: <8}</level> | "
            "<cyan>{name}</cyan>:<cyan>{line}</cyan> | "
            "<level>{message}</level>"
        ),
        colorize=True,
    )

    # ── File: JSON, rotating daily, compressed ────────────────────────────────
    logger.add(
        "logs/{{ project_slug }}_{time:YYYY-MM-DD}.log",
        level="DEBUG",
        rotation="00:00",       # new file each midnight
        retention="30 days",
        compression="gz",
        serialize=True,         # JSON format → grep / ELK / Grafana Loki
        enqueue=True,           # thread-safe async logging
    )
