name: {{ project_slug }}

services:

  # ── Application ────────────────────────────────────────────────────────────
  app:
    build:
      context: .
      dockerfile: docker/app/Dockerfile
    image: {{ project_slug }}-app:latest
    container_name: {{ project_slug }}-app
    env_file: .env
    environment:
      PYTHONUNBUFFERED: "1"
      PYTHONPATH: /app/src
      {% if include_postgres -%}
      DATABASE_URL: postgresql+asyncpg://{{ project_slug }}:${POSTGRES_PASSWORD}@postgres:5432/{{ project_slug }}_db
      {% endif -%}
      {% if include_redis -%}
      REDIS_URL: redis://redis:6379/0
      {% endif %}
    ports:
      - "{{ app_port }}:{{ app_port }}"
    volumes:
      - ./logs:/app/logs
    {% if include_postgres or include_redis %}
    depends_on:
      {% if include_postgres %}
      postgres:
        condition: service_healthy
      {% endif %}
      {% if include_redis %}
      redis:
        condition: service_healthy
      {% endif %}
    {% endif %}
    restart: unless-stopped
    networks:
      - app-net

{% if include_postgres %}
  # ── PostgreSQL ──────────────────────────────────────────────────────────────
  postgres:
    image: postgres:16-alpine
    container_name: {{ project_slug }}-postgres
    environment:
      POSTGRES_DB: {{ project_slug }}_db
      POSTGRES_USER: {{ project_slug }}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD}
    ports:
      - "5432:5432"
    volumes:
      - postgres-data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ project_slug }} -d {{ project_slug }}_db"]
      interval: 5s
      timeout: 5s
      retries: 5
    networks:
      - app-net
{% endif %}

{% if include_redis %}
  # ── Redis ───────────────────────────────────────────────────────────────────
  redis:
    image: redis:7-alpine
    container_name: {{ project_slug }}-redis
    ports:
      - "6379:6379"
    volumes:
      - redis-data:/data
    command: redis-server --appendonly yes
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 5s
      timeout: 3s
      retries: 5
    networks:
      - app-net
{% endif %}

volumes:
  {% if include_postgres %}
  postgres-data:
  {% endif %}
  {% if include_redis %}
  redis-data:
  {% endif %}

networks:
  app-net:
    driver: bridge
